{
  "manifest_version": 1,
  "extension_protocol_version": 1,
  "runtimes": [
    "process"
  ],
  "hooks": {
    "before_tool_call": {
      "permission": "tools.intercept",
      "tool_filter": true,
      "actions": [
        "continue",
        "block",
        "confirm",
        "modify"
      ]
    },
    "after_tool_call": {
      "permission": "tools.intercept",
      "tool_filter": true,
      "actions": [
        "continue"
      ]
    },
    "before_message": {
      "permission": "privacy.llm_content",
      "tool_filter": false,
      "actions": [
        "continue",
        "inject"
      ]
    },
    "on_session_start": {
      "permission": "session.lifecycle",
      "tool_filter": false,
      "actions": [
        "continue"
      ]
    },
    "on_session_end": {
      "permission": "session.lifecycle",
      "tool_filter": false,
      "actions": [
        "continue"
      ]
    }
  },
  "permissions": [
    "tools.intercept",
    "privacy.llm_content",
    "session.lifecycle",
    "tools.register"
  ],
  "reserved_permissions": [
    "tools.override",
    "providers.register"
  ],
  "matchers": {
    "input_contains": "substring match against JSON-stringified tool_input",
    "input_equals": "exact JSON equality against tool_input"
  }
}
